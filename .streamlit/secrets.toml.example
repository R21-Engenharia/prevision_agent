# Copie este arquivo como secrets.toml e preencha os valores reais
# NO Streamlit Cloud: cole o conteúdo no campo "Secrets" do dashboard
# NUNCA commite o secrets.toml no git!

PREVISION_ENDPOINT = "https://api.prevision.com.br/graphql"
PREVISION_TOKEN    = "seu-token-aqui"
PREVISION_PROJECT_ID = ""
PREVISION_PAGE_SIZE  = "100"
PREVISION_TIMEOUT    = "120"

INMETA_BASE_URL = "https://api.inmeta.com.br"
INMETA_EMAIL    = "seu-email@empresa.com"
INMETA_SENHA    = "sua-senha-aqui"

# Senha para desbloquear botoes de atualizacao no dashboard
REFRESH_PASSWORD = "sua-senha-aqui"

# ── Autenticacao Supabase ──────────────────────────────────────────────────────
# Crie um projeto gratuito em https://supabase.com e copie as chaves abaixo.
# Project Settings > API > Project URL e anon/public key
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."   # chave anon (publica)

# URL publica do app no Streamlit Cloud (para redirect do Google OAuth)
# Ex: https://seu-app.streamlit.app
APP_URL = "https://seu-app.streamlit.app"

# Dominios liberados automaticamente (sem precisar cadastrar email por email)
# Qualquer @dominio listado aqui tem acesso viewer automatico
# Separe multiplos dominios por virgula. Deixe vazio para desativar.
# Ex: ALLOWED_DOMAINS = "r21empreendimentos.com,r21engenharia.com"
ALLOWED_DOMAINS = "r21empreendimentos.com"
