# Copie para .env.local e preencha. O arquivo .env.local NÃO vai para o git.
#
# Os valores são os mesmos já usados pelo app Streamlit — estão nos
# Secrets do Streamlit Cloud (Settings → Secrets) do projeto.
#
# Sem estas variáveis o app roda em modo de desenvolvimento (sem login).

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Opcional: domínios liberados automaticamente (papel viewer), separados por vírgula.
# Quem não estiver aqui precisa constar na tabela authorized_emails.
VITE_ALLOWED_DOMAINS=r21empreendimentos.com
